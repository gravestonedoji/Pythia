# Copy this file to .env and fill in your key. .env is gitignored — never commit it.

# Anthropic API key — the only *required* secret (not needed for the daily
# forecast when PYTHIA_TRANSPORT=subscription below; still used by `reflect`).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Model transport (optional) ------------------------------------------------
# How the daily forecast reaches the model. Leave blank (or "api") for the
# metered API key above. Set to "subscription" to route forecasts through the
# local Claude Code login (`claude -p`) instead — the same claude-opus-4-8,
# billed to your plan, every row stamped +via:claude-code. Notes: needs the
# `claude` CLI on PATH (or set PYTHIA_CLAUDE_CLI to its full path); shares
# your plan's session limits with your interactive use (a maxed-out window
# means arms skip that day); the weekly `pythia reflect` still uses the API
# key (4 calls/month — pennies).
PYTHIA_TRANSPORT=
PYTHIA_CLAUDE_CLI=

# --- FRED macro arm (v1, optional) --------------------------------------------
# When set, `pythia forecast` also issues a pythia_macro arm: the same claim
# and price data as raw pythia, PLUS a point-in-time FRED macro block (Treasury
# yields, breakeven inflation, HY credit spread, VIX, dollar) so the macro
# effect is MEASURED against the price-only arms on identical claims. When left
# blank, the macro arm is a clean no-op and the price-only arms run unaffected.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Email alerts (optional) -------------------------------------------------
# Pythia can email you a summary of each batch of predictions (direction + P(up)
# + reasoning) right after it logs them. Leave these blank to disable — the
# forecast still runs, it just won't send mail.
#
# Defaults target Gmail. Gmail requires an *app password*, not your normal
# password: turn on 2-Step Verification, then create one at
# https://myaccount.google.com/apppasswords and paste the 16-char value below.
# (Put each value right after the '='. Don't add trailing inline comments — a
# space + '#' would truncate the value.)

# Your full email address. Also the default sender + recipient.
PYTHIA_SMTP_USER=
# SMTP app password (the 16-char Gmail app password works fine with the spaces
# removed). Secret — never commit.
PYTHIA_SMTP_PASSWORD=

# Optional overrides (sensible defaults if left blank):
# Where to send (default: PYTHIA_SMTP_USER)
PYTHIA_EMAIL_TO=
# From address (default: PYTHIA_SMTP_USER)
PYTHIA_EMAIL_FROM=
# SMTP host (default: smtp.gmail.com)
PYTHIA_SMTP_HOST=
# SMTP port, STARTTLS (default: 587)
PYTHIA_SMTP_PORT=
